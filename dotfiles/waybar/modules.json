{
    "custom/arch": {
        "format": "≤▒ΕΖ",
        "tooltip": true,
        "tooltip-format": "btw"
    },


    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
 
    "network#wifi": {
        "interface": "wlo1",
        "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
	"on-click": "nm-connection-editor &"
    
    },
    
    "network#ethernet": {
        "interface": "eno1",
        "format-ethernet": "ΎηΨ{ipaddr}/{cidr} ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
	"on-click": "nm-connection-editor &"
    },

	 
    
    "cpu": {
        "format": "ΎΜδ  {usage}%",

        "tooltip": true
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
	"tooltip": true
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
    "format": "{icon}    {capacity}%",
    "format-icons": ["ΎΚΕ" , "ΎΚΔ" , "ΎΚΓ" , "ΎΚΒ" , "ΎΚΑ"],
    "states": {
        "good": 80,
        "warning": 30,
        "critical": 15
    },
    "format-charging": "{icon}   {capacity}% ≤░ΓΕ",
    "format-plugged": "{icon}   {capacity}% ΎΘο"
    }

}
